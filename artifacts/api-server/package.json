{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fuser -k ${PORT:-8080}/tcp 2>/dev/null; sleep 2; export NODE_ENV=development && pnpm run build && pnpm run start",

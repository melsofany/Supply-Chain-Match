    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "ledgerstack-core": "^0.1.2",
    "nodemailer": "^9.0.0",
    "pdfkit": "^0.19.1",
    "pino": "^9.14.0",
